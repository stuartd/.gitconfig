[user]
	name = stuartd
	email = stuartd@gmail.com

[help]
	autocorrect = prompt

[column]
	ui = auto

[branch]
	sort = -committerdate

[tag]
	sort = version:refname

[init]
	defaultBranch = main

[diff]
	algorithm = histogram
	colorMoved = plain
	mnemonicPrefix = true
	renames = true

[push]
	default = simple
	autoSetupRemote = true
	followTags = true
	useForceIfIncludes = true

[fetch]
	prune = true
	all = true

[commit]
	verbose = true

[rerere]
	enabled = true
	autoUpdate = true

[core]
	excludesFile = ~/.gitignore
	editor = nano
	pager = less -FRX

[rebase]
	autoSquash = true
	autoStash = true
	updateRefs = true

[pull]
	rebase = true

[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true

[alias]
	again = !git add -A && git commit --amend --no-edit && git push --force-with-lease
	list = log --oneline --abbrev-commit --all --graph --decorate -10

[sequence]
	editor = nano
